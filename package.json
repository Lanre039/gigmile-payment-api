{
  "name": "asset-payment-api",
  "version": "1.0.0",
  "description": "REST API that applies mobility-asset customer payments to their outstanding balance.",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "worker": "tsx src/queue/worker.ts",
    "worker:dev": "tsx watch src/queue/worker.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "node -e \"require('dotenv').config(); const { execFileSync } = require('child_process'); execFileSync('psql', [process.env.DATABASE_URL, '-f', 'sql/schema.sql'], { stdio: 'inherit' });\""
  },
  "dependencies": {
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.11",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  }
}
