PORT=3000

# Postgres (use PgBouncer host:port in production - see README)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/payments
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=30000

# Redis (backs the BullMQ queue used by the async ingestion path)
REDIS_URL=redis://localhost:6379

# Set to "true" to accept payments via the queued/async endpoint worker
ENABLE_QUEUE_WORKER=true
